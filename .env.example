# Atehna Deep Agent — Configuration
# Copy to .env and fill in your values

# ── Provider (pick ONE) ──────────────────────────────────────
# Set ATEHNA_PROVIDER and the matching API key.
# If ATEHNA_PROVIDER is not set, auto-detects from whichever key is present.
# Supported: anthropic, openai, google-genai, deepseek, ollama

ATEHNA_PROVIDER=anthropic

# Provider API keys (set the one matching your provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# Ollama (local or Ollama Cloud)
# OLLAMA_API_KEY=
# OLLAMA_BASE_URL=https://ollama.com/v1

# ── Optional overrides ───────────────────────────────────────

# Override default model for your provider
# ATEHNA_MODEL=anthropic:claude-sonnet-4-6

# Trust level: strict | moderate | permissive
# ATEHNA_TRUST_LEVEL=moderate

# PinchTab browser backend
# PINCHTAB_PORT=9867
# PINCHTAB_AUTO_START=true
# PINCHTAB_MODE=headless

# ── Observability (optional) ─────────────────────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=atehna
